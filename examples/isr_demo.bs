#[max_memory(4kb)]

public fn next_tick(value: u32) -> u32 {
    return (value + (1 as u32)) & (7 as u32);
}

public fn led_on_for_tick(value: u32) -> bool {
    return (value & (1 as u32)) == (0 as u32);
}

@interrupt
public fn systick_handler() -> void {
    let tick: u32 = next_tick(3 as u32);
    let led_on: bool = led_on_for_tick(tick);
    if led_on {
        return;
    }
}
