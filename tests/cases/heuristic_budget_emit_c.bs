#[max_memory(1kb)]

fn step0() -> i32 { return 0; }
fn step1() -> i32 { return 1; }
fn step2() -> i32 { return 2; }
fn step3() -> i32 { return 3; }
fn step4() -> i32 { return 4; }
fn step5() -> i32 { return 5; }
fn step6() -> i32 { return 6; }
fn step7() -> i32 { return 7; }
fn step8() -> i32 { return 8; }
fn step9() -> i32 { return 9; }
fn step10() -> i32 { return 10; }
fn step11() -> i32 { return 11; }
fn step12() -> i32 { return 12; }
fn step13() -> i32 { return 13; }
fn step14() -> i32 { return 14; }
fn step15() -> i32 { return 15; }

fn main() -> i32 {
    let total: i32 = 0;
    total = total + step0();
    total = total + step1();
    total = total + step2();
    total = total + step3();
    total = total + step4();
    total = total + step5();
    total = total + step6();
    total = total + step7();
    total = total + step8();
    total = total + step9();
    total = total + step10();
    total = total + step11();
    total = total + step12();
    total = total + step13();
    total = total + step14();
    total = total + step15();
    return total;
}
